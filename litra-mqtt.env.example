# Configuration for the Litra MQTT bridge.
# Copy to /etc/litra-mqtt.env and edit. The installer does this for you.

# --- MQTT broker (required) -------------------------------------------------
# Point this at the broker Home Assistant uses. If you run the Mosquitto
# add-on on your HA box, this is the HA machine's IP.
LITRA_MQTT_HOST=192.168.178.x
LITRA_MQTT_PORT=1883
LITRA_MQTT_USERNAME=
LITRA_MQTT_PASSWORD=

# --- Home Assistant discovery ----------------------------------------------
# Leave as 'homeassistant' unless you changed the discovery prefix in HA.
LITRA_DISCOVERY_PREFIX=homeassistant

# --- Which lights to expose -------------------------------------------------
# Easiest: leave everything below unset and the bridge exposes every Litra
# currently connected to this host (auto-discovered).
#
# To pin specific lights (recommended for >1), set LITRA_LIGHTS to a JSON array.
# model is one of: beam_lx (front + back RGB), beam, glow (front only).
# LITRA_LIGHTS=[{"address":"FE:FA:09:E1:ED:F4","name":"Office Litra","model":"beam_lx"},{"address":"C1:AB:00:11:22:33","name":"Desk Litra","model":"beam_lx"}]
#
# Or a single light the verbose way:
# LITRA_LIGHT_ADDRESS=FE:FA:09:E1:ED:F4
# LITRA_DEVICE_NAME=Litra Beam LX
# LITRA_LIGHT_MODEL=beam_lx

# Pair/trust configured addresses on startup (1=yes). Off by default for the
# standalone path, since you typically pair once by hand. The add-on sets this on.
LITRA_PAIR_ON_START=0
LITRA_SCAN_SECONDS=8

# --- Behaviour --------------------------------------------------------------
# Seconds between availability/presence checks.
LITRA_PRESENCE_INTERVAL=5

# Set to 1 to poll the device for its real state (tracks the physical buttons)
# at the cost of extra Bluetooth traffic. Default 0 = optimistic state.
LITRA_STATE_READBACK=0

# Log level: DEBUG, INFO, WARNING, ERROR
LITRA_LOG_LEVEL=INFO
